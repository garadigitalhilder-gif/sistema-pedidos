{
  "name": "sistema-pedidos-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "api": "npm --prefix api run dev",
    "desktop": "npm --prefix desktop run dev",
    "dev": "concurrently \"npm run api\" \"npm run desktop\"",
    "install:all": "npm install --prefix api && npm install --prefix desktop",
    "deploy:ui": "npm --prefix desktop run deploy:ui",
    "build:win": "npm --prefix desktop run build:win"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
